@model DashboardViewModel
@{
    Layout = "_AdminLayout";
}

<div class="container-fluid" style="padding: 1.25rem;">
  <!-- Page Header -->
  <div class="d-flex align-items-start justify-content-between mb-3" style="gap: 1rem;">
    <div>
      <h1 style="margin:0; font-weight:700; color:var(--foreground);">لوحة التحكم</h1>
      <div style="color:var(--muted-foreground); margin-top:0.25rem;">مرحباً بك، أدمن</div>
      <div id="dashboardNow" style="color:var(--muted-foreground); font-size:0.9rem; margin-top:0.25rem;"></div>
    </div>
    <div class="d-flex align-items-center" style="gap:0.75rem;">
      <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Create" class="btn btn-sm btn-outline-primary" style="border-color:var(--theme-accent); color:var(--theme-accent);">إنشاء منتج</a>
    </div>
  </div>
  <div style="height:2px; background: linear-gradient(90deg, rgba(0,0,0,0) 0%, var(--theme-accent) 50%, rgba(0,0,0,0) 100%); opacity:0.12; margin-bottom:1rem;"></div>

  <!-- Stat Cards (6) -->
  <div class="row g-3">
    <!-- Card helper -->
    @* Today Sales *@
    <div class="col-6 col-lg-2">
      <div class="p-3" style="background:var(--card-background); border:1px solid var(--border-color); border-right:4px solid #16A34A; border-radius:var(--radius-md); transition:box-shadow var(--transition);">
        <div class="d-flex align-items-center" style="gap:0.75rem;">
          <div style="margin-left:auto;">
            <div style="width:40px; height:40px; border-radius:50%; background:#ECFDF5; display:flex; align-items:center; justify-content:center; color:#16A34A;">
              <i class="bi bi-currency-dollar"></i>
            </div>
          </div>
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--foreground);">@Model.TodaySales.ToString("N0")</div>
            <div style="font-size:0.78rem; color:var(--muted-foreground);">مبيعات اليوم</div>
          </div>
        </div>
      </div>
    </div>

    @* Month Sales *@
    <div class="col-6 col-lg-2">
      <div class="p-3" style="background:var(--card-background); border:1px solid var(--border-color); border-right:4px solid #2563EB; border-radius:var(--radius-md); transition:box-shadow var(--transition);">
        <div class="d-flex align-items-center" style="gap:0.75rem;">
          <div style="margin-left:auto;">
            <div style="width:40px; height:40px; border-radius:50%; background:#EFF6FF; display:flex; align-items:center; justify-content:center; color:#2563EB;">
              <i class="bi bi-graph-up-arrow"></i>
            </div>
          </div>
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--foreground);">@Model.MonthSales.ToString("N0")</div>
            <div style="font-size:0.78rem; color:var(--muted-foreground);">مبيعات الشهر</div>
          </div>
        </div>
      </div>
    </div>

    @* Pending Orders *@
    <div class="col-6 col-lg-2">
      <div class="p-3" style="background:var(--card-background); border:1px solid var(--border-color); border-right:4px solid #D97706; border-radius:var(--radius-md); transition:box-shadow var(--transition);">
        <div class="d-flex align-items-center" style="gap:0.75rem;">
          <div style="margin-left:auto;">
            <div style="width:40px; height:40px; border-radius:50%; background:#FFF7ED; display:flex; align-items:center; justify-content:center; color:#D97706;">
              <i class="bi bi-hourglass-split"></i>
            </div>
          </div>
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--foreground);">@Model.PendingOrders</div>
            <div style="font-size:0.78rem; color:var(--muted-foreground);">طلبات الانتظار</div>
          </div>
        </div>
      </div>
    </div>

    @* In Delivery (Shipped) *@
    <div class="col-6 col-lg-2">
      <div class="p-3" style="background:var(--card-background); border:1px solid var(--border-color); border-right:4px solid #7C3AED; border-radius:var(--radius-md); transition:box-shadow var(--transition);">
        <div class="d-flex align-items-center" style="gap:0.75rem;">
          <div style="margin-left:auto;">
            <div style="width:40px; height:40px; border-radius:50%; background:#F5F3FF; display:flex; align-items:center; justify-content:center; color:#7C3AED;">
              <i class="bi bi-truck"></i>
            </div>
          </div>
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--foreground);">@Model.ShippedOrders</div>
            <div style="font-size:0.78rem; color:var(--muted-foreground);">في التوصيل</div>
          </div>
        </div>
      </div>
    </div>

    @* Total Customers *@
    <div class="col-6 col-lg-2">
      <div class="p-3" style="background:var(--card-background); border:1px solid var(--border-color); border-right:4px solid #0D9488; border-radius:var(--radius-md); transition:box-shadow var(--transition);">
        <div class="d-flex align-items-center" style="gap:0.75rem;">
          <div style="margin-left:auto;">
            <div style="width:40px; height:40px; border-radius:50%; background:#ECFEFA; display:flex; align-items:center; justify-content:center; color:#0D9488;">
              <i class="bi bi-people"></i>
            </div>
          </div>
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--foreground);">@Model.TotalCustomers</div>
            <div style="font-size:0.78rem; color:var(--muted-foreground);">إجمالي العملاء</div>
          </div>
        </div>
      </div>
    </div>

    @* Active Products *@
    <div class="col-6 col-lg-2">
      <div class="p-3" style="background:var(--card-background); border:1px solid var(--border-color); border-right:4px solid #4F46E5; border-radius:var(--radius-md); transition:box-shadow var(--transition);">
        <div class="d-flex align-items-center" style="gap:0.75rem;">
          <div style="margin-left:auto;">
            <div style="width:40px; height:40px; border-radius:50%; background:#EEF2FF; display:flex; align-items:center; justify-content:center; color:#4F46E5;">
              <i class="bi bi-box-seam"></i>
            </div>
          </div>
          <div>
            <div style="font-size:1.5rem; font-weight:700; color:var(--foreground);">@Model.TotalActiveProducts</div>
            <div style="font-size:0.78rem; color:var(--muted-foreground);">منتجات نشطة</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Summary Bar (3 compact cards) -->
  <div class="row g-3 mt-3">
    <div class="col-12 col-md-4">
      <div style="background:var(--card-background); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:0.8rem;">
        <div class="d-flex align-items-center justify-content-between">
          <div>
            <div style="font-size:0.85rem; color:var(--muted-foreground);">نمو المبيعات مقارنة بالشهر الماضي</div>
            <div style="font-weight:700; color:var(--foreground);">@Model.MonthSales.ToString("N0")</div>
          </div>
          <div style="text-align:left;">
            @{
                var diff = Model.MonthSales - Model.LastMonthSales;
                var pct = Model.LastMonthSales != 0 ? (int)Math.Round((double)diff / (double)Model.LastMonthSales * 100) : 0;
            }
            <div style="font-weight:700; color:@(diff >= 0 ? "var(--success)" : "var(--danger)");">@(diff >= 0 ? "▲" : "▼") @Math.Abs(pct)%</div>
          </div>
        </div>
        <div style="height:36px; margin-top:0.6rem; border-radius:6px; background:linear-gradient(90deg, rgba(37,99,235,0.12), rgba(16,185,129,0.08));"></div>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <div style="background:var(--card-background); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:0.8rem;">
        <div class="d-flex align-items-center justify-content-between">
          <div>
            <div style="font-size:0.85rem; color:var(--muted-foreground);">مقارنة بالماضي</div>
            <div style="font-weight:700; color:var(--foreground);">@Model.LastMonthSales.ToString("N0")</div>
          </div>
          <div style="text-align:left; color:var(--muted-foreground);">مؤشر</div>
        </div>
        <div style="height:36px; margin-top:0.6rem; border-radius:6px; background:linear-gradient(90deg, rgba(217,119,6,0.12), rgba(124,58,237,0.08));"></div>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <div style="background:var(--card-background); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:0.8rem;">
        <div class="d-flex align-items-center justify-content-between">
          <div>
            <div style="font-size:0.85rem; color:var(--muted-foreground);">الطلبات الإجمالية</div>
            <div style="font-weight:700; color:var(--foreground);">@Model.PendingOrders + @Model.ShippedOrders</div>
          </div>
          <div style="text-align:left; color:var(--muted-foreground);">مقارنة</div>
        </div>
        <div style="height:36px; margin-top:0.6rem; border-radius:6px; background:linear-gradient(90deg, rgba(16,185,129,0.08), rgba(79,70,229,0.08));"></div>
      </div>
    </div>
  </div>

  <!-- Low Stock Alert -->
  @if (Model.LowStockProducts.Any())
  {
    <div class="mt-3" style="background:#FFFBEB; border:1px solid rgba(217,119,6,0.15); border-right:4px solid #D97706; padding:0.9rem; border-radius:var(--radius-md); display:flex; align-items:center; justify-content:space-between; gap:1rem;">
      <div style="display:flex; gap:0.75rem; align-items:center;">
        <div style="width:36px; height:36px; border-radius:6px; background:rgba(217,119,6,0.12); display:flex; align-items:center; justify-content:center; color:#D97706;">
          <i class="bi bi-exclamation-triangle"></i>
        </div>
        <div style="color:var(--foreground);">
          <div style="font-weight:700;">تنبيه: مخزون منخفض</div>
          <div style="color:var(--muted-foreground); font-size:0.9rem;">@{
              var list = Model.LowStockProducts.Take(3).Select(p => p.Name).ToList();
              var more = Model.LowStockProducts.Count - list.Count;
          }
          @string.Join("، ", list) @if (more > 0) { <text>و@more آخرون</text> }</div>
        </div>
      </div>
      <div>
        <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Index" asp-route-lowStock="true" class="btn btn-sm" style="background:var(--theme-accent); color:white;">عرض المنتجات منخفضة المخزون</a>
      </div>
    </div>
  }

  <!-- Main Content Row: Recent Orders + Top Products -->
  <div class="row g-3 mt-3">
    <div class="col-12 col-lg-8">
      <div style="background:var(--card-background); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:0.75rem;">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <div style="font-weight:700; color:var(--foreground);">آخر الطلبات</div>
          <div>
            <a asp-area="Admin" asp-controller="AdminOrders" asp-action="Index" class="btn btn-sm btn-outline-secondary">عرض الكل</a>
          </div>
        </div>

        @if (Model.RecentOrders != null && Model.RecentOrders.Any())
        {
          <div class="table-responsive">
            <table class="table align-middle" style="margin-bottom:0;">
              <thead style="background:var(--background-secondary);">
                <tr>
                  <th style="border-bottom:1px solid var(--border-color);">#</th>
                  <th style="border-bottom:1px solid var(--border-color);">العميل</th>
                  <th style="border-bottom:1px solid var(--border-color);">المبلغ</th>
                  <th style="border-bottom:1px solid var(--border-color);">الحالة</th>
                  <th style="border-bottom:1px solid var(--border-color);">التاريخ</th>
                  <th style="border-bottom:1px solid var(--border-color);">الإجراءات</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var order in Model.RecentOrders)
                {
                  <tr style="border-bottom:1px solid var(--border-color);">
                    <td style="width:60px;">@order.Id</td>
                    <td>@order.User.FullName</td>
                    <td style="color:var(--theme-accent); font-weight:700;">@order.Total.ToString("C")</td>
                    <td>
                      @{
                        var badge = order.Status switch
                        {
                            OrderStatus.Pending => (bg: "#FFFBEB", fg: "#D97706", text: "قيد الانتظار"),
                            OrderStatus.Confirmed => (bg: "#EFF6FF", fg: "#2563EB", text: "مؤكد"),
                            OrderStatus.Shipped => (bg: "#F5F3FF", fg: "#7C3AED", text: "تم الشحن"),
                            OrderStatus.Delivered => (bg: "var(--success-bg)", fg: "var(--success)", text: "تم التسليم"),
                            OrderStatus.Cancelled => (bg: "var(--danger-bg)", fg: "var(--danger)", text: "ملغى"),
                            _ => (bg: "transparent", fg: "var(--muted-foreground)", text: order.Status.ToString())
                        };
                      }
                      <span style="background:@badge.bg; color:@badge.fg; padding:0.35rem 0.6rem; border-radius:999px; font-size:0.82rem; font-weight:600;">@badge.text</span>
                    </td>
                    <td style="font-size:0.85rem; color:var(--muted-foreground);" data-created="@order.CreatedAt.ToString("o")">@order.CreatedAt.ToString("dd/MM HH:mm")</td>
                    <td>
                      <a asp-area="Admin" asp-controller="AdminOrders" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-secondary">عرض</a>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
        else
        {
          <div style="padding:1.25rem; text-align:center; color:var(--muted-foreground);">لا توجد طلبات حتى الآن.</div>
        }
      </div>
    </div>

    <div class="col-12 col-lg-4">
      <div style="background:var(--card-background); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:0.75rem;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.5rem;">
          <div style="font-weight:700; color:var(--foreground);">الأكثر مبيعاً</div>
          <div style="color:var(--muted-foreground); font-size:0.85rem;">قائمة</div>
        </div>

        <div>
          @if (Model.TopProducts != null && Model.TopProducts.Any())
          {
            var topCount = Model.TopProducts.Max(p => p.TotalSold);
            foreach (var (p, rank) in Model.TopProducts.Select((p, i) => (p, i + 1)))
            {
              var barPct = topCount > 0 ? (int)Math.Round((double)p.TotalSold / topCount * 100) : 0;
              <div style="padding:0.5rem 0; border-bottom:1px dashed var(--border-color);">
                <div class="d-flex align-items-center justify-content-between">
                  <div class="d-flex align-items-center" style="gap:0.6rem;">
                    <div style="width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:@(rank==1?"#FFD700":"#F3F4F6"); color:@(rank==1?"#825600":"#6B7280"); font-weight:700;">@rank</div>
                    <div>
                      <div style="font-weight:600; color:var(--foreground);">@p.ProductName</div>
                      <div style="font-size:0.85rem; color:var(--muted-foreground);">@p.TotalSold بيع</div>
                    </div>
                  </div>
                  <div style="width:60px; text-align:left; font-weight:700; color:var(--muted-foreground);">@p.TotalSold</div>
                </div>
                <div style="height:6px; background:var(--background); border-radius:6px; margin-top:0.5rem; overflow:hidden;">
                  <div style="height:100%; width:@barPct%; background:linear-gradient(90deg, var(--theme-accent), #4F46E5);"></div>
                </div>
              </div>
            }
          }
          else
          {
            <div style="padding:1rem; color:var(--muted-foreground); text-align:center;">لا توجد بيانات للمنتجات الأكثر مبيعاً.</div>
          }
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Dynamic dashboard clock (RTL friendly display)
  function formatDateTime(date) {
    return date.toLocaleString(undefined, { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit', year: 'numeric' });
  }
  function updateNow() {
    var now = new Date();
    document.getElementById('dashboardNow').textContent = 'الوقت الآن: ' + formatDateTime(now);
  }
  updateNow();
  setInterval(updateNow, 60000);

  // Simple relative time for orders
  function relativeTimeFrom(date) {
    var seconds = Math.floor((new Date() - date) / 1000);
    var interval = Math.floor(seconds / 31536000);
    if (interval >= 1) return interval + ' سنة';
    interval = Math.floor(seconds / 2592000);
    if (interval >= 1) return interval + ' شهر';
    interval = Math.floor(seconds / 86400);
    if (interval >= 1) return 'منذ ' + interval + ' يوم';
    interval = Math.floor(seconds / 3600);
    if (interval >= 1) return 'منذ ' + interval + ' ساعة';
    interval = Math.floor(seconds / 60);
    if (interval >= 1) return 'منذ ' + interval + ' دقيقة';
    return 'الآن';
  }
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-created]').forEach(function(el) {
      var iso = el.getAttribute('data-created');
      if (!iso) return;
      var d = new Date(iso);
      try {
        el.textContent = relativeTimeFrom(d);
      } catch (e) {
        // fallback already shows dd/MM HH:mm from server-rendered text
      }
    });
  });
</script>
