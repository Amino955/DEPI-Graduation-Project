@model IEnumerable<TellaStore.Models.Entities.Discount>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "الخصومات";
    var now = DateTime.UtcNow;
    var activeCount = Model.Count(d => d.IsActive);
    var expiredCount = Model.Count(d => d.EndDate < now);
    var totalUsage = Model?.Sum(d => d.UsageCount) ?? 0;
}

<style>
  .page-header { display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-bottom:1rem; }
  .stat-row { display:flex; gap:1rem; margin-bottom:1rem; flex-wrap:wrap; }
  .stat-card { background:var(--card-background); border:1px solid var(--border-color); border-left:4px solid; border-radius:var(--radius-md); padding:0.9rem 1rem; display:flex; align-items:center; gap:0.75rem; min-width:180px; }
  .stat-icon { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:1.05rem; }
  .stat-text { display:flex; flex-direction:column; }
  .stat-value { font-weight:800; color:var(--foreground); font-size:1rem; }
  .stat-label { font-size:0.82rem; color:var(--muted-foreground); }

  .premium-card { background: var(--card-background) !important; border: 1px solid var(--border-color) !important; border-radius: var(--radius-lg) !important; box-shadow: var(--shadow-sm) !important; padding: 1rem; }
  .admin-table { width: 100%; border-collapse: collapse; }
  .admin-table thead tr { background: var(--background-secondary) !important; }
  .admin-table th { color: var(--muted-foreground) !important; font-weight: 600; padding: 12px 16px; border: none; }
  .admin-table td { padding: 12px 16px; border-bottom: 1px solid var(--border-color) !important; color: var(--foreground); vertical-align: middle; }
  .admin-table tbody tr:hover { background: var(--background-secondary) !important; }
  .badge-type { padding:6px 10px; border-radius:999px; font-weight:700; }
  .code-tag { background:var(--background); border:1px solid var(--border-color); padding:3px 8px; border-radius:6px; font-family:monospace; display:inline-block; margin-top:6px; }
  .edit-btn { border: 1px solid var(--border-color) !important; color: var(--foreground) !important; background: transparent !important; border-radius: var(--radius-sm) !important; }
  .toggle-btn { border:1px solid #D97706; color:#D97706; background:transparent; border-radius:var(--radius-sm); }
  .delete-btn { border: 1px solid var(--danger) !important; color: var(--danger) !important; background: transparent !important; border-radius: var(--radius-sm) !important; }
  .empty-state { text-align:center; padding:2.5rem; color:var(--muted-foreground); }
</style>

<div class="page-header">
    <div>
        <h3 style="margin:0; color:var(--foreground); font-weight:800">إدارة الخصومات</h3>
        <div style="color:var(--muted-foreground); margin-top:6px">تحكم بالخصومات والكوبونات المتاحة في المتجر</div>
    </div>
    <div>
        <a asp-area="Admin" asp-controller="AdminDiscounts" asp-action="Create" class="btn btn-sm text-white" style="background:var(--theme-accent); border-radius:var(--radius-md); font-weight:700; padding:8px 14px"><i class="bi bi-plus-lg me-1"></i>إضافة خصم جديد</a>
    </div>
</div>

<!-- Summary Stats -->
<div class="stat-row">
    <div class="stat-card" style="border-left-color:var(--success);">
        <div class="stat-icon" style="background:rgba(16,185,129,0.12); color:var(--success);"><i class="bi bi-tag-fill"></i></div>
        <div class="stat-text"><div class="stat-value">@activeCount</div><div class="stat-label">خصومات نشطة</div></div>
    </div>
    <div class="stat-card" style="border-left-color:var(--danger);">
        <div class="stat-icon" style="background:rgba(220,38,38,0.06); color:var(--danger);"><i class="bi bi-calendar-x"></i></div>
        <div class="stat-text"><div class="stat-value">@expiredCount</div><div class="stat-label">خصومات منتهية</div></div>
    </div>
    <div class="stat-card" style="border-left-color:#2563EB;">
        <div class="stat-icon" style="background:#EFF6FF; color:#2563EB"><i class="bi bi-bar-chart"></i></div>
        <div class="stat-text"><div class="stat-value">@totalUsage</div><div class="stat-label">إجمالي الاستخدام</div></div>
    </div>
</div>

<div class="premium-card">
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>الاسم</th>
                    <th>النوع</th>
                    <th>القيمة</th>
                    <th>الصلاحية</th>
                    <th>الحالة</th>
                    <th>الاستخدام</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var d in Model)
                    {
                        var isExpired = d.EndDate < now;
                        var isUpcoming = d.StartDate > now;
                        <tr>
                            <td>
                                <div class="fw-bold" style="color:var(--foreground)">@d.Name</div>
                            </td>
                            <td>
                                @if (d.Type == TellaStore.Models.Entities.DiscountType.Percentage)
                                {
                                    <span class="badge badge-type" style="background:rgba(59,130,246,0.1); color:#2563EB;">نسبة مئوية</span>
                                }
                                else if (d.Type == TellaStore.Models.Entities.DiscountType.FixedAmount)
                                {
                                    <span class="badge badge-type" style="background:rgba(245,158,11,0.1); color:#D97706;">مبلغ ثابت</span>
                                }
                                else
                                {
                                    <span class="badge badge-type" style="background:rgba(124,58,237,0.1); color:#7C3AED;">شحن مجاني</span>
                                }
                            </td>
                            <td class="fw-bold">
                                @(d.Type == TellaStore.Models.Entities.DiscountType.Percentage ? $"{d.Value}%" : $"{d.Value} ج")
                            </td>
                            <td>
                                <div style="font-size:0.85rem">من: @(d.StartDate.ToString("dd/MM/yyyy"))</div>
                                <div style="font-size:0.85rem">إلى: @(d.EndDate.ToString("dd/MM/yyyy"))</div>
                            </td>
                            <td>
                                @if (isExpired)
                                {
                                    <span class="badge-pill" style="background:var(--danger-bg); color:var(--danger);">منتهي</span>
                                }
                                else if (isUpcoming)
                                {
                                    <span class="badge-pill" style="background:#FFFBEB; color:#D97706;">مجدول</span>
                                }
                                else if (d.IsActive)
                                {
                                    <span class="badge-pill" style="background:var(--success-bg); color:var(--success);">نشط</span>
                                }
                                else
                                {
                                    <span class="badge-pill" style="background:var(--background); color:var(--muted-foreground);">معطّل</span>
                                }
                            </td>
                            <td>
                                 <div class="fw-bold text-center">@d.UsageCount</div>
                             </td>
                            <td>
                                 <div class="d-flex gap-2">
                                     <button type="button" class="btn btn-sm toggle-btn" onclick="toggleDiscountActive(@d.Id, !@d.IsActive.ToString().ToLower())" title="تبديل الحالة">
                                         <i class="bi @(d.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                     </button>
                                     <a asp-area="Admin" asp-controller="AdminDiscounts" asp-action="Edit" asp-route-id="@d.Id" class="btn btn-sm edit-btn"><i class="bi bi-pencil"></i></a>
                                     <form method="post" asp-action="Delete" asp-route-id="@d.Id" onsubmit="return confirm('هل أنت متأكد من حذف الخصم؟');" class="d-inline">
                                         @Html.AntiForgeryToken()
                                         <input type="hidden" name="confirm" value="true" />
                                         <button type="submit" class="btn btn-sm delete-btn"><i class="bi bi-trash"></i></button>
                                     </form>
                                 </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-tag fs-1 d-block mb-2" style="color:var(--muted-foreground)"></i>
                                <div style="font-weight:700; color:var(--foreground)">لا توجد خصومات</div>
                                <div style="margin-top:8px;"><a asp-area="Admin" asp-controller="AdminDiscounts" asp-action="Create" class="btn btn-sm" style="background:var(--theme-accent); color:#fff">أضف خصماً جديداً</a></div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
     function toggleDiscountActive(discountId, isActive) {
         var baseUrl = '@Url.Action("Toggle", "AdminDiscounts", new { area = "Admin" })';
         fetchWithCsrf(baseUrl + '/' + discountId, {
             method: 'POST',
             headers: { 'Content-Type': 'application/json' },
             body: JSON.stringify({ isActive: isActive })
         }).then(response => {
             if (response.ok) {
                 showToast('تم تحديث الحالة بنجاح', 'success');
                 setTimeout(() => location.reload(), 700);
             } else {
                 showToast('حدث خطأ أثناء التحديث', 'error');
             }
         }).catch(() => showToast('حدث خطأ أثناء التحديث', 'error'));
     }
    </script>
}
