@model TellaStore.Models.ViewModels.Admin.ProductFormViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "إضافة منتج جديد";
}

<style>
  .premium-card {
    background: var(--card-background) !important;
    border: 1px solid var(--border-color) !important;
    border-radius: var(--radius-lg) !important;
    box-shadow: var(--shadow-sm) !important;
    padding: 1.5rem;
  }
  .form-label { color: var(--foreground) !important; font-weight: 500 !important; }
  .form-control, .form-select { background: var(--background) !important; border-color: var(--border-color) !important; color: var(--foreground) !important; border-radius: var(--radius-sm); }
  .form-control:focus, .form-select:focus { border-color: var(--theme-accent) !important; box-shadow: 0 0 0 3px rgba(var(--theme-accent-rgb), 0.15) !important; }
  .nav-tabs { border-bottom: 1px solid var(--border-color) !important; }
  .nav-tabs .nav-link { color: var(--muted-foreground) !important; border-color: transparent !important; font-weight: 500; transition: all var(--transition); }
  .nav-tabs .nav-link.active { color: var(--theme-accent) !important; background: transparent !important; border-bottom: 2px solid var(--theme-accent) !important; }
  .nav-tabs .nav-link:hover { color: var(--foreground) !important; }
  .tab-card { background: var(--card-background); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding:1rem; }
  .progress-steps { display:flex; gap:0.5rem; align-items:center; }
  .step { flex:1; text-align:center; padding:6px 8px; border-radius:6px; background:var(--background); color:var(--muted-foreground); font-weight:600; font-size:0.85rem; }
  .step.active { background: linear-gradient(90deg, rgba(37,99,235,0.08), rgba(16,185,129,0.04)); color:var(--theme-accent); border:1px solid rgba(var(--theme-accent-rgb),0.12); }
  .variant-item { background: var(--background-secondary) !important; border: 1px dashed var(--border-color) !important; border-radius: var(--radius-md) !important; padding:0.75rem; }
  .variant-action-remove { border:1px solid var(--danger); color:var(--danger); background:transparent; }
  .add-variant-btn { border:1px dashed var(--theme-accent); color:var(--theme-accent); background:transparent; border-radius:var(--radius-sm); }
  .drop-zone { border:2px dashed var(--border-color); border-radius:8px; padding:1.25rem; text-align:center; color:var(--muted-foreground); background:var(--background); }
  .image-preview-thumb { border: 1px solid var(--border-color) !important; border-radius: var(--radius-sm) !important; position:relative; overflow:hidden; }
  .image-controls { position:absolute; top:6px; left:6px; display:flex; gap:6px; }
  .image-controls button { background:rgba(0,0,0,0.45); color:white; border:none; padding:4px 6px; border-radius:6px; }
  .form-footer { border-top:1px solid var(--border-color); padding-top:1rem; margin-top:1rem; }
  @@media (max-width:767px) { .form-footer .btn { width:100%; } }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center gap-3">
        <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Index" class="btn btn-sm" style="border:1px solid var(--border-color); color:var(--foreground); border-radius:6px;"><i class="bi bi-arrow-right"></i></a>
        <div>
            <h4 style="margin:0; color:var(--foreground); font-weight:700;">إضافة منتج جديد</h4>
            <div style="color:var(--muted-foreground); font-size:0.9rem;">أدخل بيانات المنتج الأساسية، المتغيرات، والصور</div>
        </div>
    </div>
    <div style="min-width:320px;">
        <div class="progress-steps" aria-hidden="true">
            <div class="step active">البيانات الأساسية</div>
            <div class="step">المتغيرات</div>
            <div class="step">الصور</div>
        </div>
    </div>
</div>

<div class="premium-card">
    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger"></div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-3" id="productTabs" role="tablist">
            <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-basic" role="tab">المعلومات الأساسية</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-variants" role="tab">المتغيرات</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-images" role="tab">الصور</a></li>
        </ul>

        <div class="tab-content">
            <!-- Basic Info -->
            <div class="tab-pane fade show active" id="tab-basic">
                <div class="tab-card">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label">اسم المنتج <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="اسم المنتج" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div>
                                <div class="form-check form-switch">
                                    <input asp-for="IsFeatured" class="form-check-input" id="IsFeatured" />
                                    <label asp-for="IsFeatured" class="form-check-label" style="color:var(--foreground)">مميز</label>
                                </div>
                                <div class="form-check form-switch mt-2">
                                    <input asp-for="IsActive" class="form-check-input" id="IsActive" />
                                    <label asp-for="IsActive" class="form-check-label" style="color:var(--foreground)">نشط</label>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label">الوصف</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="وصف تفصيلي للمنتج..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CategoryId" class="form-label">القسم</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                                <option value="">اختر القسم</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">

                            <label asp-for="BasePrice" class="form-label">السعر الأساسي</label>
                            <div class="input-group">
                                <input asp-for="BasePrice" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                                <span class="input-group-text">جنيه</span>
                            </div>
                            <span asp-validation-for="BasePrice" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">

                            <label class="form-label">الموسم</label>
                            <div class="btn-group" role="group" aria-label="Season">
                                <input type="radio" class="btn-check" name="Season" id="seasonSummer" autocomplete="off" value="0" @(Model.Season == TellaStore.Models.Entities.Season.Summer ? "checked" : "") />
                                <label class="btn btn-sm btn-outline-secondary" for="seasonSummer">صيفي</label>

                                <input type="radio" class="btn-check" name="Season" id="seasonWinter" autocomplete="off" value="1" @(Model.Season == TellaStore.Models.Entities.Season.Winter ? "checked" : "") />
                                <label class="btn btn-sm btn-outline-secondary" for="seasonWinter">شتوي</label>

                                <input type="radio" class="btn-check" name="Season" id="seasonAll" autocomplete="off" value="2" @(Model.Season == TellaStore.Models.Entities.Season.AllSeason ? "checked" : "") />
                                <label class="btn btn-sm btn-outline-secondary" for="seasonAll">كل الأوقات</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Variants -->
            <div class="tab-pane fade" id="tab-variants">
                    <div id="variants-container">
                        @for (int i = 0; i < Model.Variants.Count; i++)
                        {
                            <div class="variant-item mb-2">
                                <div class="row g-2 align-items-end">
                                    <input type="hidden" asp-for="Variants[i].Id" />
                                    <div class="col-md-3">
                                        <label class="form-label">اللون</label>
                                        <div class="d-flex" style="gap:0.5rem; align-items:center;">
                                            <input asp-for="Variants[i].ColorHex" class="form-control form-control-color" type="color" style="width:56px; height:38px; padding:0;" />
                                            <input asp-for="Variants[i].Color" class="form-control" placeholder="اسم اللون" />
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">المقاس</label>
                                        <input asp-for="Variants[i].Size" class="form-control" placeholder="S, M, L..." />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">المخزون</label>
                                        <input asp-for="Variants[i].Stock" class="form-control" type="number" min="0" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">تعديل السعر</label>
                                        <input asp-for="Variants[i].PriceModifier" class="form-control" type="number" step="0.01" min="0" />
                                    </div>
                                    <div class="col-md-2 d-flex justify-content-end">
                                        <button type="button" class="btn btn-sm variant-action-remove" onclick="removeVariant(this)" title="حذف المتغير"><i class="bi bi-x-lg"></i></button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="mt-2">
                        <button type="button" class="add-variant-btn btn btn-sm" onclick="addVariant()"><i class="bi bi-plus-lg me-1"></i> إضافة متغير</button>
                    </div>
                </div>

            <!-- Images -->
            <div class="tab-pane fade" id="tab-images">
                <div class="tab-card">
                    <label class="form-label">الصور (حتى 6 صور)</label>
                    <div class="drop-zone mb-3" id="dropZone" onclick="document.getElementById('NewImagesInput').click();">
                        <div>اسحب الصور هنا أو اضغط للرفع</div>
                        <div class="muted" style="font-size:0.85rem;">اسحب وأفلت أو اختر ملفات من جهازك</div>
                        <input id="NewImagesInput" type="file" name="NewImages" class="form-control d-none" multiple accept="image/*" onchange="validateImageCount(this)" />
                    </div>
                    <div id="image-preview" class="row g-2 mt-2"></div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="form-footer d-flex gap-2 justify-content-end mt-3">
            <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Index" class="btn" style="border:1px solid var(--border-color); color:var(--foreground); border-radius:var(--radius-sm);">إلغاء</a>
            <button type="submit" class="btn" style="background:var(--theme-accent); color:#fff; border-radius:var(--radius-md); padding:10px 20px; font-weight:700;">حفظ المنتج</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
let variantIndex = @Model.Variants.Count;

function addVariant() {
    const container = document.getElementById('variants-container');
    const html = `
        <div class="variant-item mb-2">
            <div class="row g-2 align-items-end">
                <input type="hidden" name="Variants[${variantIndex}].Id" value="" />
                <div class="col-md-3">
                    <label class="form-label">اللون</label>
                    <div class="d-flex" style="gap:0.5rem; align-items:center;">
                        <input name="Variants[${variantIndex}].ColorHex" class="form-control form-control-color" type="color" style="width:56px; height:38px; padding:0;" />
                        <input name="Variants[${variantIndex}].Color" class="form-control" placeholder="اسم اللون" />
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">المقاس</label>
                    <input name="Variants[${variantIndex}].Size" class="form-control" placeholder="S, M, L..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">المخزون</label>
                    <input name="Variants[${variantIndex}].Stock" class="form-control" type="number" min="0" value="0" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">تعديل السعر</label>
                    <input name="Variants[${variantIndex}].PriceModifier" class="form-control" type="number" step="0.01" min="0" value="0" />
                </div>
                <div class="col-md-2 d-flex justify-content-end">
                    <button type="button" class="btn btn-sm variant-action-remove" onclick="removeVariant(this)"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
        </div>
    `;
    container.insertAdjacentHTML('beforeend', html);
    variantIndex++;
}

function removeVariant(btn) {
    btn.closest('.variant-item').remove();
}

function validateImageCount(input) {
    if (input.files.length > 6) {
        alert('يمكنك رفع حتى 6 صور فقط');
        input.value = '';
        return;
    }

    const preview = document.getElementById('image-preview');
    preview.innerHTML = '';

    Array.from(input.files).forEach((file, index) => {
        const reader = new FileReader();
        reader.onload = function(e) {
            const col = document.createElement('div');
            col.className = 'col-6 col-md-2';
            const wrapper = document.createElement('div');
            wrapper.className = 'position-relative image-preview-thumb';
            wrapper.style.aspectRatio = '1';
            wrapper.innerHTML = `
                <img src="${e.target.result}" class="img-fluid w-100 h-100" style="object-fit:cover;" />
                <div class="image-controls">
                    <button type="button" class="btn-set-main" title="اجعل رئيسية">رئيسية</button>
                    <button type="button" class="btn-remove-image" title="إزالة">إزالة</button>
                </div>
                <small class="d-block text-center muted mt-1">${index === 0 ? 'رئيسية' : ''}</small>
            `;
            col.appendChild(wrapper);
            preview.appendChild(col);

            // Add simple interactions (UI only) for remove/main
            wrapper.querySelector('.btn-remove-image').addEventListener('click', function(){ col.remove(); });
            wrapper.querySelector('.btn-set-main').addEventListener('click', function(){
                // mark this as main visually
                document.querySelectorAll('#image-preview small').forEach(s=>s.textContent='');
                wrapper.querySelector('small').textContent = 'رئيسية';
            });
        };
        reader.readAsDataURL(file);
    });
}

// progress-steps animation handler
document.querySelectorAll('#productTabs .nav-link').forEach((tab, index) => {
    tab.addEventListener('shown.bs.tab', function () {
        document.querySelectorAll('.progress-steps .step').forEach((s, i) => {
            s.classList.toggle('active', i === index);
        });
    });
});
</script>
}
