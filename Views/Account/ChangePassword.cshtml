@model ChangePasswordViewModel
@{
  Layout = "_Layout";
  ViewData["Title"] = "تغيير كلمة المرور";
}

<style>
  /* Container */
  .change-password-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 200px);
    padding: 2rem 1rem;
  }

  .change-password-wrapper {
    width: 100%;
    max-width: 480px;
  }

  /* Page Heading */
  .page-heading {
    text-align: center;
    margin-bottom: 2rem;
  }

  .page-heading h1 {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--foreground);
    font-weight: 800;
    font-size: 1.8rem;
    margin: 0;
  }

  .page-heading-icon {
    font-size: 1.3rem;
    color: var(--theme-accent);
  }

  /* Card */
  .change-card {
    background: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-md);
  }

  /* Form Group */
  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-label {
    display: block;
    font-weight: 700;
    color: var(--foreground);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  /* Input Wrapper with Icon and Toggle */
  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    right: 0.75rem;
    color: var(--muted-foreground);
    font-size: 1rem;
    pointer-events: none;
  }

  .form-control {
    width: 100%;
    background: var(--background);
    border: 1px solid var(--border-color);
    color: var(--foreground);
    border-radius: var(--radius-sm);
    padding: 0.75rem 2.5rem 0.75rem 0.95rem;
    font-size: 0.95rem;
    font-family: var(--font-ar);
    transition: all var(--transition);
  }

  .form-control:focus {
    outline: none;
    background: var(--background);
    color: var(--foreground);
    border-color: var(--theme-accent);
    box-shadow: 0 0 0 3px rgba(var(--theme-accent-rgb), 0.1);
  }

  /* Password Toggle Button */
  .password-toggle {
    position: absolute;
    left: 0.75rem;
    background: none;
    border: none;
    color: var(--muted-foreground);
    cursor: pointer;
    padding: 0;
    font-size: 1rem;
    display: flex;
    align-items: center;
    transition: color var(--transition);
  }

  .password-toggle:hover {
    color: var(--theme-accent);
  }

  /* Password Strength Meter */
  .strength-container {
    margin-top: 0.5rem;
  }

  .strength-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    color: var(--muted-foreground);
  }

  .strength-text {
    font-weight: 700;
  }

  .strength-bar {
    width: 100%;
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    overflow: hidden;
    transition: all var(--transition);
  }

  .strength-progress {
    height: 100%;
    width: 0%;
    border-radius: 3px;
    transition: all var(--transition);
  }

  .strength-weak {
    background: #ef4444;
  }

  .strength-medium {
    background: #f59e0b;
    width: 66%;
  }

  .strength-strong {
    background: #10b981;
    width: 100%;
  }

  /* Validation */
  .validation-summary {
    background: var(--danger-bg);
    color: var(--danger);
    border: 1px solid var(--danger);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .validation-error {
    color: var(--danger);
    font-size: 0.8rem;
    margin-top: 0.25rem;
    display: block;
  }

  /* Buttons */
  .submit-btn {
    width: 100%;
    background: var(--theme-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1rem;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .submit-btn:hover {
    opacity: 0.9;
  }

  .cancel-link {
    text-align: center;
    display: block;
    color: var(--theme-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity var(--transition);
  }

  .cancel-link:hover {
    opacity: 0.8;
  }

  /* Password Requirements (Optional Helper Text) */
  .password-requirements {
    background: rgba(var(--theme-accent-rgb), 0.05);
    border: 1px solid rgba(var(--theme-accent-rgb), 0.1);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--muted-foreground);
  }

  .password-requirements li {
    margin-bottom: 0.25rem;
  }
</style>

<div class="change-password-container">
  <div class="change-password-wrapper">
    <!-- Page Heading -->
    <div class="page-heading">
      <h1>
        <i class="bi bi-lock page-heading-icon"></i>
        تغيير كلمة المرور
      </h1>
    </div>

    <!-- Form Card -->
    <div class="change-card">
      <form method="post" asp-action="ChangePassword">
        @Html.AntiForgeryToken()

        <!-- Validation Summary -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
          <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <!-- Current Password -->
        <div class="form-group">
          <label asp-for="CurrentPassword" class="form-label">
            كلمة المرور الحالية
          </label>
          <div class="input-wrapper">
            <input asp-for="CurrentPassword"
                   type="password"
                   class="form-control"
                   placeholder="أدخل كلمة المرور الحالية"
                   dir="ltr"
                   id="currentPasswordField">
            <i class="bi bi-lock input-icon"></i>
            <button type="button"
                    class="password-toggle"
                    onclick="togglePassword('currentPasswordField', 'eyeIconCurrent')"
                    tabindex="-1">
              <i class="bi bi-eye" id="eyeIconCurrent"></i>
            </button>
          </div>
          <span asp-validation-for="CurrentPassword" class="validation-error"></span>
        </div>

        <!-- New Password -->
        <div class="form-group">
          <label asp-for="NewPassword" class="form-label">
            كلمة المرور الجديدة
          </label>
          <div class="input-wrapper">
            <input asp-for="NewPassword"
                   type="password"
                   class="form-control"
                   placeholder="ادخل كلمة مرور قوية"
                   dir="ltr"
                   id="newPasswordField"
                   oninput="updatePasswordStrength()">
            <i class="bi bi-lock input-icon"></i>
            <button type="button"
                    class="password-toggle"
                    onclick="togglePassword('newPasswordField', 'eyeIconNew')"
                    tabindex="-1">
              <i class="bi bi-eye" id="eyeIconNew"></i>
            </button>
          </div>
          <span asp-validation-for="NewPassword" class="validation-error"></span>

          <!-- Password Strength Meter -->
          <div class="strength-container">
            <div class="strength-label">
              <span>قوة كلمة المرور:</span>
              <span class="strength-text" id="strengthText"></span>
            </div>
            <div class="strength-bar">
              <div class="strength-progress" id="strengthProgress"></div>
            </div>
          </div>
        </div>

        <!-- Confirm Password -->
        <div class="form-group">
          <label asp-for="ConfirmPassword" class="form-label">
            تأكيد كلمة المرور الجديدة
          </label>
          <div class="input-wrapper">
            <input asp-for="ConfirmPassword"
                   type="password"
                   class="form-control"
                   placeholder="أعد كتابة كلمة المرور"
                   dir="ltr"
                   id="confirmPasswordField">
            <i class="bi bi-lock input-icon"></i>
            <button type="button"
                    class="password-toggle"
                    onclick="togglePassword('confirmPasswordField', 'eyeIconConfirm')"
                    tabindex="-1">
              <i class="bi bi-eye" id="eyeIconConfirm"></i>
            </button>
          </div>
          <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="submit-btn">
          <i class="bi bi-check-circle"></i>
          تحديث كلمة المرور
        </button>

        <!-- Cancel Link -->
        <a asp-action="Profile" class="cancel-link">
          رجوع للحساب
        </a>
      </form>
    </div>
  </div>
</div>

<script>
  function togglePassword(fieldId, iconId) {
    const passwordField = document.getElementById(fieldId);
    const eyeIcon = document.getElementById(iconId);
    
    if (passwordField.type === 'password') {
      passwordField.type = 'text';
      eyeIcon.classList.remove('bi-eye');
      eyeIcon.classList.add('bi-eye-slash');
    } else {
      passwordField.type = 'password';
      eyeIcon.classList.remove('bi-eye-slash');
      eyeIcon.classList.add('bi-eye');
    }
  }

  function updatePasswordStrength() {
    const passwordField = document.getElementById('newPasswordField');
    const password = passwordField.value;
    const strengthProgress = document.getElementById('strengthProgress');
    const strengthText = document.getElementById('strengthText');
    
    let strength = 0;
    let strengthLabel = '';
    
    // Check password length
    if (password.length >= 8) strength++;
    if (password.length >= 12) strength++;
    
    // Check for uppercase
    if (/[A-Z]/.test(password)) strength++;
    
    // Check for lowercase
    if (/[a-z]/.test(password)) strength++;
    
    // Check for numbers
    if (/[0-9]/.test(password)) strength++;
    
    // Check for special characters
    if (/[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)) strength++;
    
    // Update strength bar and text
    strengthProgress.className = 'strength-progress';
    
    if (strength <= 2) {
      strengthLabel = 'ضعيفة';
      strengthProgress.classList.add('strength-weak');
      strengthProgress.style.width = '33%';
    } else if (strength <= 4) {
      strengthLabel = 'متوسطة';
      strengthProgress.classList.add('strength-medium');
      strengthProgress.style.width = '66%';
    } else {
      strengthLabel = 'قوية';
      strengthProgress.classList.add('strength-strong');
      strengthProgress.style.width = '100%';
    }
    
    strengthText.textContent = strengthLabel;
  }
</script>
