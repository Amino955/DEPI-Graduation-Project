@model ForgotPasswordViewModel
@{
  Layout = "_Layout";
  ViewData["Title"] = "نسيت كلمة المرور";
}

<style>
  /* Page Container */
  .forgot-password-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    padding: 2rem 1rem;
    background: var(--background);
  }

  .forgot-password-wrapper {
    width: 100%;
    max-width: 420px;
  }

  /* Decorative Icon */
  .icon-container {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .icon-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: rgba(var(--theme-accent-rgb), 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--theme-accent);
    animation: scaleIn 0.6s ease-out;
  }

  @@keyframes scaleIn {
    from {
      transform: scale(0.8);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  /* Content */
  .forgot-heading {
    text-align: center;
    margin-bottom: 2rem;
  }

  .forgot-heading h1 {
    color: var(--foreground);
    font-weight: 800;
    font-size: clamp(1.6rem, 3vw, 1.9rem);
    margin: 0 0 0.75rem 0;
  }

  .forgot-heading p {
    color: var(--muted-foreground);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Card */
  .forgot-card {
    background: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-md);
  }

  /* Form */
  .form-group {
    margin-bottom: 2rem;
  }

  .form-label {
    display: block;
    font-weight: 700;
    color: var(--foreground);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  /* Input Wrapper */
  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    right: 0.75rem;
    color: var(--muted-foreground);
    font-size: 1rem;
    pointer-events: none;
  }

  .form-control {
    width: 100%;
    background: var(--background);
    border: 1px solid var(--border-color);
    color: var(--foreground);
    border-radius: var(--radius-sm);
    padding: 0.75rem 2.5rem 0.75rem 0.95rem;
    font-size: 0.95rem;
    font-family: var(--font-ar);
    transition: all var(--transition);
  }

  .form-control:focus {
    outline: none;
    background: var(--background);
    color: var(--foreground);
    border-color: var(--theme-accent);
    box-shadow: 0 0 0 3px rgba(var(--theme-accent-rgb), 0.1);
  }

  /* Validation */
  .validation-summary {
    background: var(--danger-bg);
    color: var(--danger);
    border: 1px solid var(--danger);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .validation-error {
    color: var(--danger);
    font-size: 0.8rem;
    margin-top: 0.25rem;
    display: block;
  }

  /* Submit Button */
  .submit-btn {
    width: 100%;
    background: var(--theme-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1rem;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .submit-btn:hover {
    opacity: 0.9;
  }

  /* Links */
  .back-to-login {
    text-align: center;
    margin-top: 1.5rem;
    color: var(--muted-foreground);
    font-size: 0.9rem;
  }

  .back-to-login a {
    color: var(--theme-accent);
    text-decoration: none;
    font-weight: 700;
    transition: opacity var(--transition);
  }

  .back-to-login a:hover {
    opacity: 0.8;
  }

  /* Info Box */
  .info-box {
    background: rgba(var(--theme-accent-rgb), 0.05);
    border: 1px solid rgba(var(--theme-accent-rgb), 0.1);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--muted-foreground);
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .info-box i {
    color: var(--theme-accent);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
</style>

<div class="forgot-password-container">
  <div class="forgot-password-wrapper">
    <!-- Decorative Icon -->
    <div class="icon-container">
      <div class="icon-circle">
        <i class="bi bi-lock"></i>
      </div>
    </div>

    <!-- Heading -->
    <div class="forgot-heading">
      <h1>نسيت كلمة المرور؟</h1>
      <p>أدخل بريدك الإلكتروني وسنرسل لك رابط إعادة التعيين</p>
    </div>

    <!-- Form Card -->
    <div class="forgot-card">
      <form method="post" asp-action="ForgotPassword">
        @Html.AntiForgeryToken()

        <!-- Validation Summary -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
          <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <!-- Email Field -->
        <div class="form-group">
          <label asp-for="Email" class="form-label">
            البريد الإلكتروني
          </label>
          <div class="input-wrapper">
            <input asp-for="Email"
                   type="email"
                   class="form-control"
                   placeholder="example@email.com"
                   dir="ltr"
                   required>
            <i class="bi bi-envelope input-icon"></i>
          </div>
          <span asp-validation-for="Email" class="validation-error"></span>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="submit-btn">
          <i class="bi bi-send"></i>
          إرسال رابط الاسترداد
        </button>

        <!-- Info Box -->
        <div class="info-box">
          <i class="bi bi-info-circle"></i>
          <span>سنرسل تعليمات إعادة التعيين إلى بريدك الإلكتروني خلال دقائق</span>
        </div>
      </form>
    </div>

    <!-- Back to Login Link -->
    <p class="back-to-login">
      تذكرت كلمة المرور؟
      <a asp-action="Login">العودة لتسجيل الدخول</a>
    </p>
  </div>
</div>
