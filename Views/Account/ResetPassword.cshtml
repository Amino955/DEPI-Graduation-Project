@model ResetPasswordViewModel
@{
  Layout = "_Layout";
  ViewData["Title"] = "إعادة تعيين كلمة المرور";
}

<style>
  /* Page Container */
  .reset-password-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    padding: 2rem 1rem;
    background: var(--background);
  }

  .reset-password-wrapper {
    width: 100%;
    max-width: 420px;
  }

  /* Decorative Icon */
  .icon-container {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .icon-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: rgba(var(--theme-accent-rgb), 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--theme-accent);
    animation: scaleIn 0.6s ease-out;
  }

  @@keyframes scaleIn {
    from {
      transform: scale(0.8);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  /* Content */
  .reset-heading {
    text-align: center;
    margin-bottom: 2rem;
  }

  .reset-heading h1 {
    color: var(--foreground);
    font-weight: 800;
    font-size: clamp(1.6rem, 3vw, 1.9rem);
    margin: 0 0 0.75rem 0;
  }

  .reset-heading p {
    color: var(--muted-foreground);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Card */
  .reset-card {
    background: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-md);
  }

  /* Form */
  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-label {
    display: block;
    font-weight: 700;
    color: var(--foreground);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  /* Input Wrapper */
  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    right: 0.75rem;
    color: var(--muted-foreground);
    font-size: 1rem;
    pointer-events: none;
  }

  .form-control {
    width: 100%;
    background: var(--background);
    border: 1px solid var(--border-color);
    color: var(--foreground);
    border-radius: var(--radius-sm);
    padding: 0.75rem 2.5rem 0.75rem 0.95rem;
    font-size: 0.95rem;
    font-family: var(--font-ar);
    transition: all var(--transition);
  }

  .form-control:focus {
    outline: none;
    background: var(--background);
    color: var(--foreground);
    border-color: var(--theme-accent);
    box-shadow: 0 0 0 3px rgba(var(--theme-accent-rgb), 0.1);
  }

  /* Password Toggle Button */
  .password-toggle {
    position: absolute;
    left: 0.75rem;
    background: none;
    border: none;
    color: var(--muted-foreground);
    cursor: pointer;
    padding: 0;
    font-size: 1rem;
    display: flex;
    align-items: center;
    transition: color var(--transition);
  }

  .password-toggle:hover {
    color: var(--theme-accent);
  }

  /* Password Strength Meter */
  .strength-container {
    margin-top: 0.5rem;
  }

  .strength-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    color: var(--muted-foreground);
  }

  .strength-text {
    font-weight: 700;
  }

  .strength-bar {
    width: 100%;
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    overflow: hidden;
    transition: all var(--transition);
  }

  .strength-progress {
    height: 100%;
    width: 0%;
    border-radius: 3px;
    transition: all var(--transition);
  }

  .strength-weak {
    background: #ef4444;
  }

  .strength-medium {
    background: #f59e0b;
    width: 66%;
  }

  .strength-strong {
    background: #10b981;
    width: 100%;
  }

  /* Validation */
  .validation-summary {
    background: var(--danger-bg);
    color: var(--danger);
    border: 1px solid var(--danger);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .validation-error {
    color: var(--danger);
    font-size: 0.8rem;
    margin-top: 0.25rem;
    display: block;
  }

  /* Submit Button */
  .submit-btn {
    width: 100%;
    background: var(--theme-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1rem;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .submit-btn:hover {
    opacity: 0.9;
  }

  /* Success Message */
  .success-message {
    background: var(--success-bg);
    color: var(--success);
    border: 1px solid var(--success);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
</style>

<div class="reset-password-container">
  <div class="reset-password-wrapper">
    <!-- Decorative Icon -->
    <div class="icon-container">
      <div class="icon-circle">
        <i class="bi bi-key"></i>
      </div>
    </div>

    <!-- Heading -->
    <div class="reset-heading">
      <h1>إعادة تعيين كلمة المرور</h1>
      <p>أدخل كلمة مرور جديدة وقوية</p>
    </div>

    <!-- Form Card -->
    <div class="reset-card">
      <form method="post" asp-action="ResetPassword">
        @Html.AntiForgeryToken()
        
        <!-- Hidden Fields -->
        <input asp-for="Token" type="hidden">
        <input asp-for="Email" type="hidden">

        <!-- Validation Summary -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
          <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <!-- New Password -->
        <div class="form-group">
          <label asp-for="NewPassword" class="form-label">
            كلمة المرور الجديدة
          </label>
          <div class="input-wrapper">
            <input asp-for="NewPassword"
                   type="password"
                   class="form-control"
                   placeholder="ادخل كلمة مرور قوية"
                   dir="ltr"
                   id="newPasswordField"
                   oninput="updatePasswordStrength()"
                   required>
            <i class="bi bi-lock input-icon"></i>
            <button type="button"
                    class="password-toggle"
                    onclick="togglePassword('newPasswordField', 'eyeIconNew')"
                    tabindex="-1">
              <i class="bi bi-eye" id="eyeIconNew"></i>
            </button>
          </div>
          <span asp-validation-for="NewPassword" class="validation-error"></span>

          <!-- Password Strength Meter -->
          <div class="strength-container">
            <div class="strength-label">
              <span>قوة كلمة المرور:</span>
              <span class="strength-text" id="strengthText"></span>
            </div>
            <div class="strength-bar">
              <div class="strength-progress" id="strengthProgress"></div>
            </div>
          </div>
        </div>

        <!-- Confirm Password -->
        <div class="form-group">
          <label asp-for="ConfirmPassword" class="form-label">
            تأكيد كلمة المرور
          </label>
          <div class="input-wrapper">
            <input asp-for="ConfirmPassword"
                   type="password"
                   class="form-control"
                   placeholder="أعد كتابة كلمة المرور"
                   dir="ltr"
                   id="confirmPasswordField"
                   required>
            <i class="bi bi-lock input-icon"></i>
            <button type="button"
                    class="password-toggle"
                    onclick="togglePassword('confirmPasswordField', 'eyeIconConfirm')"
                    tabindex="-1">
              <i class="bi bi-eye" id="eyeIconConfirm"></i>
            </button>
          </div>
          <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="submit-btn">
          <i class="bi bi-check-circle"></i>
          تعيين كلمة المرور الجديدة
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  function togglePassword(fieldId, iconId) {
    const passwordField = document.getElementById(fieldId);
    const eyeIcon = document.getElementById(iconId);
    
    if (passwordField.type === 'password') {
      passwordField.type = 'text';
      eyeIcon.classList.remove('bi-eye');
      eyeIcon.classList.add('bi-eye-slash');
    } else {
      passwordField.type = 'password';
      eyeIcon.classList.remove('bi-eye-slash');
      eyeIcon.classList.add('bi-eye');
    }
  }

  function updatePasswordStrength() {
    const passwordField = document.getElementById('newPasswordField');
    const password = passwordField.value;
    const strengthProgress = document.getElementById('strengthProgress');
    const strengthText = document.getElementById('strengthText');
    
    let strength = 0;
    let strengthLabel = '';
    
    // Check password length
    if (password.length >= 8) strength++;
    if (password.length >= 12) strength++;
    
    // Check for uppercase
    if (/[A-Z]/.test(password)) strength++;
    
    // Check for lowercase
    if (/[a-z]/.test(password)) strength++;
    
    // Check for numbers
    if (/[0-9]/.test(password)) strength++;
    
    // Check for special characters
    if (/[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)) strength++;
    
    // Update strength bar and text
    strengthProgress.className = 'strength-progress';
    
    if (strength <= 2) {
      strengthLabel = 'ضعيفة';
      strengthProgress.classList.add('strength-weak');
      strengthProgress.style.width = '33%';
    } else if (strength <= 4) {
      strengthLabel = 'متوسطة';
      strengthProgress.classList.add('strength-medium');
      strengthProgress.style.width = '66%';
    } else {
      strengthLabel = 'قوية';
      strengthProgress.classList.add('strength-strong');
      strengthProgress.style.width = '100%';
    }
    
    strengthText.textContent = strengthLabel;
  }
</script>
