@model HomeViewModel
@{
  Layout = "_Layout";
  ViewData["Title"] = "الرئيسية";
  var categoryImages = new Dictionary<string, string> {
    { "men", "https://images.unsplash.com/photo-1617127365659-c47fa864d8bc?w=900&q=90&auto=format&fit=crop" },
    { "women", "https://images.unsplash.com/photo-1523381210434-271e8be1f52b?w=900&q=90&auto=format&fit=crop" },
    { "kids", "https://images.unsplash.com/photo-1503944583220-79d8926ad5e2?w=900&q=90&auto=format&fit=crop" },
  };
}

<style>
  html, body {
    overflow-x: clip;
  }

  .home-page {
    overflow-x: clip;
    background: var(--background);
  }

  .home-hero {
    min-height: min(680px, calc(100vh - 92px));
    display: flex;
    align-items: center;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(12, 18, 24, 0.84) 0%, rgba(12, 18, 24, 0.62) 46%, rgba(12, 18, 24, 0.28) 100%),
      url("https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=1800&q=90&auto=format&fit=crop") center/cover no-repeat;
  }

  .home-hero::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 92px;
    background: linear-gradient(180deg, transparent, var(--background));
    z-index: -1;
  }

  .hero-inner {
    width: 100%;
    padding: 5.5rem 0 6rem;
  }

  .hero-copy {
    max-width: 680px;
    color: #fff;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.8rem;
    border: 1px solid rgba(255,255,255,0.28);
    border-radius: 999px;
    color: rgba(255,255,255,0.86);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
    font-weight: 700;
    font-size: 0.84rem;
    margin-bottom: 1.15rem;
  }

  .hero-title {
    max-width: 640px;
    font-size: clamp(2.25rem, 4.5rem, 4.6rem);
    line-height: 1.08;
    font-weight: 900;
    margin: 0 0 1.1rem;
    letter-spacing: 0;
  }

  .hero-text {
    max-width: 560px;
    color: rgba(255,255,255,0.8);
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: 1.8rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .hero-btn {
    min-height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 14px;
    padding: 0.9rem 1.35rem;
    font-weight: 800;
    text-decoration: none;
    transition: transform var(--transition), background var(--transition), border-color var(--transition);
  }

  .hero-btn:hover {
    transform: translateY(-2px);
  }

  .hero-btn.primary {
    color: var(--foreground);
    background: #fff;
  }

  .hero-btn.secondary {
    color: #fff;
    border: 1px solid rgba(255,255,255,0.42);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    max-width: 560px;
    margin-top: 2rem;
  }

  .hero-stat {
    padding: 0.9rem;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.16);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
  }

  .hero-stat strong {
    display: block;
    color: #fff;
    font-size: 1.05rem;
    margin-bottom: 0.2rem;
  }

  .hero-stat span {
    color: rgba(255,255,255,0.72);
    font-size: 0.78rem;
  }

  .home-section {
    padding: 4.5rem 0;
  }

  .home-section.soft {
    background: var(--background-secondary);
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .section-title {
    margin: 0;
    color: var(--foreground);
    font-size: 1.8rem;
    font-weight: 900;
  }

  .section-subtitle {
    margin: 0.35rem 0 0;
    color: var(--muted-foreground);
    font-size: 0.95rem;
  }

  .section-link {
    color: var(--theme-accent);
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .category-tile {
    min-height: 250px;
    position: relative;
    overflow: hidden;
    border-radius: 18px;
    display: flex;
    align-items: end;
    padding: 1.15rem;
    text-decoration: none;
    background: #111;
  }

  .category-tile img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }

  .category-tile::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 20%, rgba(0,0,0,0.72) 100%);
  }

  .category-tile:hover img {
    transform: scale(1.05);
  }

  .category-content {
    position: relative;
    z-index: 1;
    color: #fff;
  }

  .category-content strong {
    display: block;
    font-size: 1.25rem;
    font-weight: 900;
  }

  .category-content span {
    display: block;
    color: rgba(255,255,255,0.76);
    font-size: 0.86rem;
    margin-top: 0.25rem;
  }

  .discount-strip {
    padding: 1rem 0;
    background: var(--foreground);
    color: #fff;
    overflow: hidden;
  }

  .discount-track {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 0.15rem;
  }

  .discount-track::-webkit-scrollbar {
    display: none;
  }

  .discount-pill {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.1);
    color: #fff;
    font-size: 0.88rem;
    font-weight: 800;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .benefit-item {
    padding: 1.15rem;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
  }

  .benefit-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--theme-accent);
    background: rgba(var(--theme-accent-rgb), 0.09);
    margin-bottom: 0.8rem;
  }

  .benefit-item h3 {
    margin: 0 0 0.25rem;
    color: var(--foreground);
    font-size: 0.98rem;
    font-weight: 900;
  }

  .benefit-item p {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 0.84rem;
    line-height: 1.6;
  }

  @@media (max-width: 991px) {
    .home-hero {
      min-height: auto;
    }

    .hero-inner {
      padding: 4rem 0 4.5rem;
    }

    .category-grid,
    .product-grid,
    .benefits-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @@media (max-width: 575px) {
    .hero-title {
      font-size: 2.25rem;
    }

    .hero-stats,
    .category-grid,
    .product-grid,
    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .section-head {
      align-items: start;
      flex-direction: column;
    }

    .category-tile {
      min-height: 210px;
    }
  }
</style>

<div class="home-page">
  <section class="home-hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <div class="hero-kicker">
          <i class="bi bi-bag-check"></i>
          اختيارات يومية بجودة موثوقة
        </div>
        <h1 class="hero-title">ملابس عملية وأنيقة لكل أفراد البيت</h1>
        <p class="hero-text">
          تسوق رجالي، أطفال، وقطع يومية مختارة بعناية. صور واضحة، أسعار مباشرة، وتجربة شراء سريعة من غير زحمة.
        </p>
        <div class="hero-actions">
          <a href="/products" class="hero-btn primary">
            تسوق الآن
            <i class="bi bi-arrow-left"></i>
          </a>
          <a href="/products?IsFeatured=true" class="hero-btn secondary">
            المنتجات المميزة
            <i class="bi bi-stars"></i>
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <strong>توصيل سريع</strong>
            <span>لمحافظات مصر</span>
          </div>
          <div class="hero-stat">
            <strong>دفع آمن</strong>
            <span>كاش عند الاستلام</span>
          </div>
          <div class="hero-stat">
            <strong>منتجات مختارة</strong>
            <span>للبيت والخروج</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  @if (Model.ActiveDiscounts.Any())
  {
    <section class="discount-strip">
      <div class="container">
        <div class="discount-track">
          <span class="discount-pill">
            <i class="bi bi-tag-fill"></i>
            العروض الحالية
          </span>
          @foreach (var d in Model.ActiveDiscounts.Take(6))
          {
            <span class="discount-pill">
              @d.Name
              <span>
                @(d.Type == DiscountType.Percentage ? $"خصم {d.Value}%" : $"خصم {d.Value:N0} جنيه")
              </span>
            </span>
          }
        </div>
      </div>
    </section>
  }

  <section class="home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-title">تسوق حسب القسم</h2>
          <p class="section-subtitle">ابدأ من القسم المناسب واعرض المنتجات بسرعة.</p>
        </div>
        <a href="/products" class="section-link">كل المنتجات <i class="bi bi-arrow-left"></i></a>
      </div>

      <div class="category-grid">
        @foreach (var cat in Model.ParentCategories.Take(3))
        {
          var slug = cat.Slug ?? "";
          var catImg = categoryImages.ContainsKey(slug) ? categoryImages[slug] : "https://images.unsplash.com/photo-1489987707025-afc232f7ea0f?w=900&q=80&auto=format&fit=crop";
          <a href="/products?CategoryId=@cat.Id" class="category-tile">
            <img src="@catImg" alt="@cat.Name" loading="lazy" />
            <span class="category-content">
              <strong>@cat.Name</strong>
              @if (cat.SubCategories?.Any() == true)
              {
                <span>@cat.SubCategories.Count(s => s.IsActive) أقسام فرعية</span>
              }
              else
              {
                <span>اكتشف المنتجات</span>
              }
            </span>
          </a>
        }
      </div>
    </div>
  </section>

  @if (Model.FeaturedProducts.Any())
  {
    <section class="home-section soft">
      <div class="container">
        <div class="section-head">
          <div>
            <h2 class="section-title">منتجات تستحق التجربة</h2>
            <p class="section-subtitle">اختيارات مميزة جاهزة للشراء.</p>
          </div>
          <a href="/products?IsFeatured=true" class="section-link">عرض الكل <i class="bi bi-arrow-left"></i></a>
        </div>
        <div class="product-grid">
          @foreach (var p in Model.FeaturedProducts.Take(8))
          {
            @await Html.PartialAsync("_ProductCard", p)
          }
        </div>
      </div>
    </section>
  }

  @if (Model.LatestProducts.Any())
  {
    <section class="home-section">
      <div class="container">
        <div class="section-head">
          <div>
            <h2 class="section-title">وصل حديثًا</h2>
            <p class="section-subtitle">أحدث المنتجات المضافة للمتجر.</p>
          </div>
          <a href="/products" class="section-link">عرض الكل <i class="bi bi-arrow-left"></i></a>
        </div>
        <div class="product-grid">
          @foreach (var p in Model.LatestProducts.Take(8))
          {
            @await Html.PartialAsync("_ProductCard", p)
          }
        </div>
      </div>
    </section>
  }

  <section class="home-section soft">
    <div class="container">
      <div class="benefits-grid">
        @{
          var features = new[] {
            new { Icon = "bi-truck", Title = "توصيل سريع", Desc = "متابعة واضحة حتى الاستلام." },
            new { Icon = "bi-arrow-return-right", Title = "إرجاع مرن", Desc = "سهولة في التعامل مع الطلبات." },
            new { Icon = "bi-shield-check", Title = "دفع آمن", Desc = "الدفع عند الاستلام متاح." },
            new { Icon = "bi-headset", Title = "دعم متاح", Desc = "مساعدة عند كل خطوة." },
          };
        }
        @foreach (var f in features)
        {
          <div class="benefit-item">
            <div class="benefit-icon">
              <i class="bi @f.Icon"></i>
            </div>
            <h3>@f.Title</h3>
            <p>@f.Desc</p>
          </div>
        }
      </div>
    </div>
  </section>
</div>
