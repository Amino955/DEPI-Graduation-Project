@model Order
@{
  Layout = "_Layout";
  ViewData["Title"] = "تم تأكيد طلبك بنجاح";
  var currentStatus = Model.Status;
  int stepIndex = currentStatus switch {
      OrderStatus.Pending => 1,
      OrderStatus.Confirmed => 2,
      OrderStatus.Processing => 2,
      OrderStatus.Shipped => 3,
      OrderStatus.Delivered => 4,
      _ => 0
  };
  bool stepPending = stepIndex >= 1;
  bool stepConfirmed = stepIndex >= 2;
  bool stepShipped = stepIndex >= 3;
  bool stepDelivered = stepIndex >= 4;
}

<style>
  .page-confirmation {
    direction: rtl;
    min-height: calc(100vh - 100px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1rem;
    background: var(--background);
  }
  .confirmation-card {
    position: relative;
    max-width: 600px;
    width: 100%;
    background: var(--card-background);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: 3rem;
    overflow: hidden;
  }
  .confirmation-card::before,
  .confirmation-card::after {
    content: "";
    position: absolute;
    width: 10px;
    height: 10px;
    background: var(--theme-accent);
    border-radius: 2px;
    opacity: 0.9;
    transform: rotate(20deg);
  }
  .confirmation-card::before {
    top: 18px;
    left: 24px;
    box-shadow: 44px 28px var(--theme-accent), 92px 10px var(--success), 28px 88px var(--warning);
  }
  .confirmation-card::after {
    bottom: 24px;
    right: 18px;
    box-shadow: -42px -30px var(--theme-accent), -82px -8px var(--danger), -26px -72px var(--success);
  }
  .success-icon {
    margin: 0 auto 1.75rem;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(var(--theme-accent-rgb), 0.16);
    color: var(--theme-accent);
    box-shadow: 0 0 0 rgba(var(--theme-accent-rgb), 0.2);
    animation: popIn 0.7s ease-out;
  }
  .success-icon i {
    font-size: 3.5rem;
  }
  @@keyframes popIn {
    0% { transform: scale(0.3); opacity: 0; }
    70% { transform: scale(1.05); opacity: 1; }
    100% { transform: scale(1); }
  }
  .confirmation-title {
    text-align: center;
    color: var(--foreground);
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 0.75rem;
  }
  .confirmation-subtitle {
    text-align: center;
    color: var(--muted-foreground);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .order-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--theme-accent);
    color: #fff;
    border-radius: var(--radius-full);
    padding: 0.85rem 1.4rem;
    font-weight: 700;
    margin: 0 auto 2rem;
  }
  .status-timeline {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .status-step {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-radius: var(--radius-xl);
    background: var(--background-secondary);
    border: 1px solid var(--border-color);
  }
  .status-step.active {
    background: rgba(var(--theme-accent-rgb), 0.08);
    border-color: var(--theme-accent);
  }
  .status-step.current {
    box-shadow: 0 0 0 4px rgba(var(--theme-accent-rgb), 0.08);
  }
  .status-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--border-color);
    border: 2px solid var(--border-color);
  }
  .status-step.active .status-dot {
    background: var(--theme-accent);
    border-color: var(--theme-accent);
  }
  .status-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .status-title {
    color: var(--foreground);
    font-weight: 700;
  }
  .status-label {
    color: var(--muted-foreground);
    font-size: 0.92rem;
  }
  .details-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: 2rem;
  }
  .detail-card {
    background: var(--background-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1rem 1.1rem;
  }
  .detail-card h6 {
    margin-bottom: 0.6rem;
    color: var(--foreground);
    font-size: 0.95rem;
    font-weight: 700;
  }
  .detail-card p {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 0.92rem;
    line-height: 1.7;
  }
  .detail-card.full {
    grid-column: 1 / -1;
  }
  .items-section {
    margin-bottom: 2rem;
  }
  .items-section h3 {
    margin-bottom: 1rem;
    color: var(--foreground);
    font-size: 1.1rem;
    font-weight: 800;
  }
  .order-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border-color);
  }
  .order-item:last-child {
    border-bottom: none;
  }
  .item-thumb {
    width: 68px;
    height: 68px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    border: 1px solid var(--border-color);
  }
  .item-info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .item-name {
    color: var(--foreground);
    font-weight: 700;
  }
  .item-meta {
    color: var(--muted-foreground);
    font-size: 0.9rem;
  }
  .item-price {
    color: var(--foreground);
    font-weight: 700;
    text-align: left;
  }
  .actions-row {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .actions-row .btn {
    min-width: 160px;
    padding: 0.95rem 1.4rem;
    border-radius: var(--radius-xl);
    font-weight: 700;
    text-decoration: none;
  }
  .actions-row .btn-primary {
    background: var(--theme-accent);
    color: #fff;
    border: 1px solid transparent;
  }
  .actions-row .btn-secondary {
    background: transparent;
    color: var(--foreground);
    border: 1px solid var(--border-color);
  }
  .share-line {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    color: var(--muted-foreground);
    font-size: 0.9rem;
    flex-wrap: wrap;
  }
  .share-icons {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .share-icons i {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--background-secondary);
    color: var(--theme-accent);
    border: 1px solid var(--border-color);
  }
  @@media (max-width: 767.98px) {
    .details-grid {
      grid-template-columns: 1fr;
    }
    .status-step {
      grid-template-columns: 1fr;
    }
    .status-step .status-dot {
      justify-self: center;
    }
    .actions-row {
      flex-direction: column;
    }
  }
</style>

<div class="page-confirmation">
  <div class="confirmation-card">
    <div class="success-icon">
      <i class="bi bi-check2-circle"></i>
    </div>
    <h1 class="confirmation-title">شكراً على طلبك! 🎉</h1>
    <p class="confirmation-subtitle">تم تأكيد طلبك بنجاح. يمكنك الآن متابعة حالة الطلب أو العودة للتسوق بسهولة.</p>
    <div class="order-pill">رقم الطلب: #@Model.Id</div>

    <div class="status-timeline">
      <div class="status-step @(stepPending ? "active" : "") @(currentStatus == OrderStatus.Pending ? "current" : "")">
        <div class="status-info">
          <span class="status-title">في انتظار التأكيد</span>
          <span class="status-label">Pending</span>
        </div>
        <span class="status-dot"></span>
      </div>
      <div class="status-step @(stepConfirmed ? "active" : "") @(currentStatus == OrderStatus.Confirmed ? "current" : "")">
        <div class="status-info">
          <span class="status-title">تم التأكيد</span>
          <span class="status-label">Confirmed</span>
        </div>
        <span class="status-dot"></span>
      </div>
      <div class="status-step @(stepShipped ? "active" : "") @(currentStatus == OrderStatus.Shipped ? "current" : "")">
        <div class="status-info">
          <span class="status-title">في الطريق</span>
          <span class="status-label">Shipped</span>
        </div>
        <span class="status-dot"></span>
      </div>
      <div class="status-step @(stepDelivered ? "active" : "") @(currentStatus == OrderStatus.Delivered ? "current" : "")">
        <div class="status-info">
          <span class="status-title">تم التسليم</span>
          <span class="status-label">Delivered</span>
        </div>
        <span class="status-dot"></span>
      </div>
    </div>

    <div class="details-grid">
      <div class="detail-card full">
        <h6>عنوان التوصيل</h6>
        <p>@Model.ShippingStreet<br />@Model.ShippingCity، @Model.ShippingGovernorate</p>
      </div>
      <div class="detail-card">
        <h6>طريقة الدفع</h6>
        <p>الدفع عند الاستلام</p>
      </div>
      <div class="detail-card">
        <h6>التوصيل المتوقع</h6>
        <p>خلال 3-5 أيام عمل</p>
      </div>
      <div class="detail-card">
        <h6>تاريخ الطلب</h6>
        <p>@Model.CreatedAt.ToString("dd/MM/yyyy")</p>
      </div>
      <div class="detail-card">
        <h6>الإجمالي</h6>
        <p>@Model.Total.ToString("N0") جنيه</p>
      </div>
    </div>

    <div class="items-section">
      <h3>عناصر الطلب</h3>
      @foreach (var item in Model.Items)
      {
        <div class="order-item">
          <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)" alt="@item.ProductName" class="item-thumb" />
          <div class="item-info">
            <span class="item-name">@item.ProductName</span>
            <span class="item-meta">اللون: @item.Color · المقاس: @item.Size</span>
            <span class="item-meta">الكمية: @item.Quantity</span>
          </div>
          <div class="item-price">@item.TotalPrice.ToString("N0") ج</div>
        </div>
      }
    </div>

    <div class="actions-row">
      <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">تتبع طلبك</a>
      <a href="/products" class="btn btn-secondary">متابعة التسوق</a>
    </div>

    <div class="share-line">
      <span>شارك فرحة التسوق</span>
      <div class="share-icons">
        <i class="bi bi-facebook"></i>
        <i class="bi bi-twitter"></i>
        <i class="bi bi-instagram"></i>
      </div>
    </div>
  </div>
</div>
