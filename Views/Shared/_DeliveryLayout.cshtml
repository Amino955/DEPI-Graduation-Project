<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")طِلّة | التوصيل</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="~/css/site.css">
  <style>
    .delivery-topbar {
      background: var(--theme-accent) !important;
      color: #fff !important;
      padding: 0.85rem 1.25rem !important;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .delivery-order-card {
      background: var(--card-background) !important;
      border: 1px solid var(--border-color) !important;
      border-radius: var(--radius-lg) !important;
      padding: 1.25rem !important;
      margin-bottom: 1rem !important;
      box-shadow: var(--shadow-sm) !important;
    }
    .status-badge {
      border-radius: 9999px;
      padding: 4px 12px;
      font-size: 12px;
      font-weight: 600;
      display: inline-block;
    }
    .status-shipped {
      background: #F5F3FF;
      color: #7C3AED;
    }
    .status-delivered {
      background: var(--success-bg);
      color: var(--success);
    }
    .status-failed {
      background: var(--danger-bg);
      color: var(--danger);
    }
    .btn-dark-tella {
      background: var(--foreground) !important;
      color: var(--background) !important;
      border-radius: var(--radius-sm);
      font-weight: 600;
    }
    .btn-dark-tella:hover {
      opacity: 0.9;
    }
  </style>
</head>
<body style="background:var(--background)">

<nav class="delivery-topbar">
  <div class="d-flex align-items-center gap-2">
    <div class="d-inline-flex align-items-center justify-content-center"
         style="width:36px;height:36px;background:rgba(255,255,255,0.15);border-radius:8px;padding:0">
      <i class="bi bi-truck text-white fs-5"></i>
    </div>
    <div>
      <div class="text-white fw-bold" style="line-height:1.2; font-weight: 700">طِلّة</div>
      <div style="font-size:0.72rem;color:rgba(255,255,255,0.85)">نظام التوصيل</div>
    </div>
  </div>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white" style="font-size:0.88rem;color:rgba(255,255,255,0.85)">@User.Identity!.Name</span>
    <form method="post" action="/account/logout" class="m-0">
      @Html.AntiForgeryToken()
      <button type="submit" class="btn btn-sm"
              style="border:1px solid rgba(255,255,255,0.3);color:#fff;background:transparent;border-radius:8px">
        خروج
      </button>
    </form>
  </div>
</nav>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show m-3 mb-0" role="alert">
    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger alert-dismissible fade show m-3 mb-0">
    <i class="bi bi-x-circle me-2"></i>@TempData["Error"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Warning"] != null)
{
  <div class="alert alert-warning alert-dismissible fade show m-3 mb-0">
    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Warning"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

<div class="container py-4" style="max-width:700px">@RenderBody()</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
